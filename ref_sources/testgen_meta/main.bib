@Book{Miller:CGP,
  editor =       "Julian F. Miller",
  title =        "Cartesian Genetic Programming",
  publisher =    "Springer",
  year =         "2011",
  series =       "Natural Computing Series",
  keywords =     "genetic algorithms, genetic programming, Cartesian

@InProceedings{untch:mutation,
  author =       "Roland H. Untch and A. Jefferson Offutt and Mary Jean
                 Harrold",
  title =        "Mutation Analysis Using Mutant Schemata",
  editor =       "Thomas Ostrand and Elaine Weyuker",
  booktitle =    "International Symposium on
                 Software Testing and Analysis ({ISSTA})",
  year =         "1993",
  pages =        "139--148",
  URL =          "http://www.acm.org/pubs/articles/proceedings/issta/154183/p139-untch/p139-untch.pdf",
  genterms =     "ALGORITHMS, EXPERIMENTATION, LANGUAGES",
  categories =   "D.2.5 Software, SOFTWARE ENGINEERING, Testing and
                 Debugging. D.3.3 Software, PROGRAMMING LANGUAGES,
                 Language Constructs and Features. F.3.3 Theory of
                 Computation, LOGICS AND MEANINGS OF PROGRAMS, Studies
                 of Program Constructs, Program and recursion schemes.
                 D.3.1 Software, PROGRAMMING LANGUAGES, Formal
                 Definitions and Theory, Syntax.",
  abstract =     "Mutation analysis is a powerful technique for
                 assessing and improving the quality of test data used
                 to unit test software. Unfortunately, current automated
                 mutation analysis systems suffer from severe
                 performance problems. This paper presents a new method
                 for performing mutation analysis that uses
                 \emph{program schemata} to encode all mutants for a
                 program into one \emph{metaprogram}, which is
                 subsequently compiled and run at speeds substantially
                 higher than achieved by previous interpretive systems.
                 Preliminary performance improvements of over 300 are
                 reported. This method has the additional advantages of
                 being easier to implement than interpretive systems,
                 being simpler to port across a wide range of hardware
                 and software platforms, and using the same compiler and
                 run-time support system that is used during development
                 and/or deployment.",
  annote =       "incomplete",
}



@InProceedings{gallagher:surgeon,
         author        = {Keith Brian Gallagher},
         title         = {Evaluating the Surgeon's Assistant: Results of a Pilot
                         Study},
         pages         = {236-244},
         booktitle     = {International Conference on Software Maintenance ({ICSE '92})},
         year          = {1992},
publisher = cspress,
  address = "Los Alamitos, California, USA",
         month         = nov,
         abstract      = {Maintaining computer programs is a difficult, time
                         consuming and expensive task. Maintainers face two
                         major
                         obstacles. The first is understanding the program to be
                         modified. The second is validating the change while
                         insuring that the unmodified parts have not been
                         accidentally impacted. Traditional methods used to
                         understand and modify a program overwhelm the
                         maintainer of
                         today's large systems. A possible solution is to modify
                         the
                         process under which maintenance is performed. The
                         modification of the process entails providing a tool to
                         the
                         maintainer so that the focus of interest, and a
                         technique
                         by which these changes can be assured to be completely
                         contained in the focus of interest, and a technique by
                         which these changes can be syntactically merged back
                         into
                         the existing system. We have constructed a software
                         tool,
                         the Surgeon's Assistant, that is a prototype
                         implementation
                         of this modified software maintenance process model.
                         This
                         paper presents the result of the pilot study of the
                         Surgeon's Assistant.},
         class         = {Reengineering_Tools,Surgeon_s_Assistant}
}






@Article{yhr:program-integration,
  author =       "Wuu Yang and Susan Horwitz and Thomas Reps",
  title =        "A Program Integration Algorithm that Accommodates
                 Semantics-Preserving Transformations",
  journal =      "ACM Transactions on Software Engineering and
                 Methodology",
  publisher =    "ACM Press",
  publaddr =     "New York , NY , USA",
  ISSN =         "1049-331X",
  year =         "1992",
  volume =       "1",
  month =        jul,
  number =       "3",
  pages =        "310--354",
  abstract =     "Given a program \emph{Base} and two variants, \emph{A}
                 and \emph{B}, each created by modifying separate copies
                 of \emph{Base}, the goal of program integration is to
                 determine whether the modifications interfere, and if
                 they do not, to create an integrated program that
                 includes both sets of changes as well as the portions
                 of \emph{Base} preserved in both variants. Text-based
                 integration techniques, such as the one used by the
                 Unix \emph{diff3} utility, are obviously unsatisfactory
                 because one has no guarantees about how the execution
                 behavior of the integrated program relates to the
                 behaviors of \emph{Base}, \emph{A}, and \emph{B}. The
                 first program-integration algorithm to provide such
                 guarantees was developed by Horwitz et
                 al.~\cite{1989:toplas:horwitz}. However, a limitation
                 of that algorithm is that it incorporates no notion of
                 semantics-preserving transformations. This limitation
                 causes the algorithm to be overly conservative in its
                 definition of interference. For example, if one variant
                 changes the \emph{way} a computation is performed
                 (without changing the values computed) while the other
                 variant adds code that uses the result of the
                 computation, the algorithm would classify those changes
                 as interfering. This paper describes a new integration
                 algorithm that is able to accommodate
                 semantics-preserving transformations."
 
}



@TechReport{gouranton:deriving,
  pages =        "20 p.",
  type =         "Technical Report",
  number =       "RR-3413",
  institution =  "Inria, Institut National de Recherche en Informatique
                 et en Automatique",
  title =        "Deriving Analysers by Folding\&sol;Unfolding of
                 Natural Semantics and a Case Study: Slicing",
  bibdate =      "April 1, 1998",
  year = 1998,
  author =       "Valerie Gouranton",
  language =     "A",
  abstract =     "Nous consid\&eacute;rons la sp\&eacute;cification
                 d\&apos;un analyseur comme la composition de deux
                 fonctions\&nbsp;: une fonction s\&eacute;mantique, qui
                 rend un arbre de d\&eacute;rivation de la
                 s\&eacute;mantique naturelle, et une
                 propri\&eacute;t\&eacute; d\&eacute;finie par
                 r\&eacute;currence sur les arbres de
                 d\&eacute;rivation. Une d\&eacute;finition
                 r\&eacute;cursive d\&apos;un analyseur dynamique peut
                 \&ecirc;tre obtenue par des transformations de
                 programmes (pliage\&sol;d\&eacute;pliage),
                 combin\&eacute;e avec des techniques de
                 d\&eacute;forestation. Nous appliquons notre cadre
                 g\&eacute;n\&eacute;rique \&agrave; la
                 d\&eacute;rivation d\&apos;une analyse
                 d\&apos;\&eacute;lagage pour un langage de
                 programmation logique. We consider specifications of
                 analysers expressed as compositions of two functions: a
                 semantic function, which returns a natural semantics
                 derivation tree, and a property defined by recurrence
                 on derivation trees. A recursive definition of a
                 dynamic analyser can be obtained by fold\&sol;unfold
                 program transformation combined with deforestation. We
                 apply our framework to the derivation of a slicing
                 analysis for a logic programming language.",
}








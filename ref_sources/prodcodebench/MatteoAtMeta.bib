@article{stolee10YearsLater2025,
  title = {10 {{Years Later}}: {{Revisiting How Developers Search}} for {{Code}}},
  shorttitle = {10 {{Years Later}}},
  author = {Stolee, Kathryn T. and Welp, Tobias and Sadowski, Caitlin and Elbaum, Sebastian},

@misc{xiaAgentRMEnhancingAgent2025,
  title = {{{AgentRM}}: {{Enhancing Agent Generalization}} with {{Reward Modeling}}},
  shorttitle = {{{AgentRM}}},
  author = {Xia, Yu and Fan, Jingru and Chen, Weize and Yan, Siyu and Cong, Xin and Zhang, Zhong and Lu, Yaxi and Lin, Yankai and Liu, Zhiyuan and Sun, Maosong},

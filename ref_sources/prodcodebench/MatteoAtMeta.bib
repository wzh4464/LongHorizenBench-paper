  keywords = {Computer Science - Artificial Intelligence,Computer Science - Software Engineering},
  file = {/Users/mattepalte/Zotero/storage/JWHZ3YFE/Majgaonkar et al. - 2025 - Understanding Code Agent Behaviour An Empirical Study of Success and Failure Trajectories.pdf;/Users/mattepalte/Zotero/storage/SAABPZS9/2511.html}
}


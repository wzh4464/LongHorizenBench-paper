@inproceedings{kulsumCaseStudyLLM2024,
  title = {A {{Case Study}} of {{LLM}} for {{Automated Vulnerability Repair}}: {{Assessing Impact}} of {{Reasoning}} and {{Patch Validation Feedback}}},

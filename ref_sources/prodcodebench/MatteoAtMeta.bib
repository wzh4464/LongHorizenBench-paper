@misc{ehsaniWhereAICoding2026,
  title = {Where {{Do AI Coding Agents Fail}}? {{An Empirical Study}} of {{Failed Agentic Pull Requests}} in {{GitHub}}},
  shorttitle = {Where {{Do AI Coding Agents Fail}}?},
  author = {Ehsani, Ramtin and Pathak, Sakshi and Rawal, Shriya and Mujahid, Abdullah Al and Imran, Mia Mohammad and Chatterjee, Preetha},

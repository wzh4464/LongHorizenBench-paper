% FIRST PAGE: bigger header to fit logo
\fancypagestyle{firstpage}{%
  \fancyhf{}%
  % enough height for logo + rule
  \setlength{\headheight}{50pt}%
  % space between rule and text
  \setlength{\headsep}{10pt}%
  \renewcommand{\headrulewidth}{1.5pt}%
  % logo sits so its top aligns with where the rule usually is

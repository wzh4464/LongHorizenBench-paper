  % }%
}

% EVERY OTHER PAGE: normal header height and separation
\fancypagestyle{plain}{%
  \fancyhf{}%
  \setlength{\headheight}{20pt}% default head height
  \setlength{\headsep}{20pt}% default space
  \renewcommand{\headrulewidth}{0pt}% remove bar at top of page
  \fancyfoot[C]{\thepage}%
}
% \makeatother

% apply
\AtBeginDocument{\thispagestyle{firstpage}}
\pagestyle{plain}



\def\@maketitle{\vbox{\hsize\textwidth
%\linewidth\hsize \vskip 0.1in \toptitlebar \centering
\vspace{5pt}
\centering
{\Large\bf \@title\par}    
\def\And{\end{tabular}\hfil\linebreak[0]\hfil
    \begin{tabular}[t]{c}\bf\rule{\z@}{24pt}\ignorespaces}%
\def\AND{\end{tabular}\hfil\linebreak[4]\hfil
    \begin{tabular}[t]{c}\bf\rule{\z@}{24pt}\ignorespaces}%
\begin{tabular}[t]{c}\bf\rule{\z@}{24pt}\@author\end{tabular}%

\vskip 0.3in minus 0.1in}}


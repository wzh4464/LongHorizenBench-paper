% Specify the dimensions of each page

\setlength{\paperheight}{11in}
\setlength{\paperwidth}{8.5in}


\oddsidemargin 0in    %   Note \oddsidemargin = \evensidemargin
\evensidemargin 0in
\marginparwidth 0.07 true in
